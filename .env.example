# AE Daily Briefs — Environment Configuration
# Copy to .env and fill in your actual values.
# Never commit .env to source control.

# ─── HubSpot ──────────────────────────────────────────────────────────────────
# Private App token from HubSpot → Settings → Integrations → Private Apps
HUBSPOT_API_KEY=your_hubspot_private_app_token

# ─── Google Calendar ──────────────────────────────────────────────────────────
# OAuth2 credentials from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# After completing the OAuth2 flow, set these tokens (for dev / quick testing).
# In production, use GOOGLE_SERVICE_ACCOUNT_JSON instead.
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# OR: paste a service account JSON as a single line (for CI / production)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── AE Identity ──────────────────────────────────────────────────────────────
# The HubSpot owner ID for this AE (numeric string, e.g. "12345678")
AE_ID=your_hubspot_owner_id

# The AE's work email (used to filter Google Calendar events)
AE_EMAIL=ae@yourcompany.com

# The AE's Google Calendar ID (usually their work email, or "primary")
GOOGLE_CALENDAR_ID=ae@yourcompany.com

# ─── Google Gemini (AI Intelligence) ─────────────────────────────────────────
# API key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ─── Slack ────────────────────────────────────────────────────────────────────
# Bot token from Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Where to deliver the brief: set ONE of these
SLACK_USER_ID=UXXXXXXXXXX       # Slack member ID (recommended — sends as DM)
# SLACK_CHANNEL_ID=CXXXXXXXXXX  # Channel ID (alternative)

# ─── App Settings ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
API_TIMEOUT_MS=30000

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_CACHE=true
ENABLE_AI=true
ENABLE_SLACK_DELIVERY=false    # Set true to actually send Slack DMs
