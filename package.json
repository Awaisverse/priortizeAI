{
  "name": "ae-daily-briefs",
  "version": "0.1.0",
  "description": "AI-powered Sales Account Executive Daily Brief Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:perf": "jest --testPathPattern=tests/performance",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --check src/**/*.ts",
    "format:fix": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "setup": "npm install && npm run build",
    "setup:phase1": "npm install && npm run build",
    "setup:phase2": "npm run build",
    "setup:phase3": "npm run build",
    "setup:phase4": "npm run build",
    "phase1:gate-review": "npm run test:unit -- tests/data-collection",
    "phase2:gate-review": "npm run test:integration -- tests/integration/phase1-phase2.test.ts",
    "phase3:gate-review": "npm run test:integration -- tests/integration/fullPipeline.test.ts",
    "deploy:staging": "echo 'Deploy to staging'",
    "deploy:production": "echo 'Deploy to production'",
    "rollback:production": "echo 'Rollback production'",
    "health:check": "node dist/health/healthCheck.js",
    "monitor:live": "echo 'Real-time monitoring'",
    "errors:recent": "echo 'Recent errors'",
    "errors:24h": "echo 'Last 24 hours errors'",
    "metrics:show": "echo 'System metrics'",
    "metrics:current": "echo 'Current metrics'",
    "verify:apis": "echo 'Verify API connectivity'",
    "verify:deployment": "npm run test:e2e",
    "debug:execution": "echo 'Debug execution'",
    "report:daily": "echo 'Generate daily report'",
    "security:scan": "npm audit"
  },
  "keywords": [
    "sales",
    "crm",
    "ai",
    "automation",
    "hubspot",
    "google-calendar",
    "claude",
    "slack"
  ],
  "author": "Sales Engineering Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@slack/web-api": "^7.17.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "googleapis": "^173.0.0",
    "joi": "^17.11.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
